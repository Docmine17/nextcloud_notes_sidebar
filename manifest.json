{
  "manifest_version": 3,
  "name": "Nextcloud Notes Sidebar",
  "version": "1.0.0",
  "description": "Acesse suas notas do Nextcloud rapidamente pela barra lateral.",
  "permissions": ["storage"],
  "background": {
    "scripts": ["scripts/background.js"]
  },
  "action": {
    "default_title": "Abrir Nextcloud Notes",
    "default_icon": "icons/favicon.svg"
  },
  "sidebar_action": {
    "default_title": "Nextcloud Notes",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/favicon.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "browser_style": false
  }
}
